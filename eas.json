{
  "cli": {
    "version": ">= 16.31.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "ios": { "simulator": false },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://renewal-dev.barfdogserver.com"
      }
    },
    "ios-simulator": {
      "developmentClient": true,
      "ios": { "simulator": true },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://renewal-dev.barfdogserver.com"
      }
    },
    "preview": {
      "distribution": "internal",
      "android": { "buildType": "apk" },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://renewal-dev.barfdogserver.com"
      }
    },
    "production": {
      "autoIncrement": true,
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.barfdogserver.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
